# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME=Food Demand Forecasting API
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=food_forecast
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/food_forecast
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_ECHO=false

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── JWT / Auth ──────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-run-openssl-rand-hex-32-to-generate
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key

# ─── Pinecone ────────────────────────────────────────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=food-forecast

# ─── Weather API ─────────────────────────────────────────────────────────────
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key

# ─── Sentry ──────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ─── Frontend (Next.js) ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
